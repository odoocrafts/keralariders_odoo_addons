<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Portal Record Rules -->
        <record id="logistics_seller_portal_rule" model="ir.rule">
            <field name="name">Portal Seller Rule</field>
            <field name="model_id" ref="model_logistics_seller"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="logistics_wallet_portal_rule" model="ir.rule">
            <field name="name">Portal Wallet Rule</field>
            <field name="model_id" ref="model_logistics_wallet"/>
            <field name="domain_force">[('seller_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="logistics_wallet_transaction_portal_rule" model="ir.rule">
            <field name="name">Portal Wallet Transaction Rule</field>
            <field name="model_id" ref="model_logistics_wallet_transaction"/>
            <field name="domain_force">[('wallet_id.seller_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="logistics_wallet_recharge_request_portal_rule" model="ir.rule">
            <field name="name">Portal Wallet Recharge Request Rule</field>
            <field name="model_id" ref="model_logistics_wallet_recharge_request"/>
            <field name="domain_force">[('seller_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="logistics_shipment_portal_rule" model="ir.rule">
            <field name="name">Portal Shipment Rule</field>
            <field name="model_id" ref="model_logistics_shipment"/>
            <field name="domain_force">[('seller_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
