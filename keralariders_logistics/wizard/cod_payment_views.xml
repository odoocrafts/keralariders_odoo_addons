<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<record id="view_logistics_cod_payment_wizard_form" model="ir.ui.view">
		<field name="name">logistics.cod.payment.wizard.form</field>
		<field name="model">logistics.cod.payment.wizard</field>
		<field name="arch" type="xml">
			<form string="COD Payment">
				<sheet>
					<group>
                        <group>
                            <field name="shipment_id" readonly="1" force_save="1"/>
                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="from_account_id" domain="[('account_type', 'in', ('cod_customer', 'seller'))]" options="{'no_create': True}"/>
                            <field name="to_account_id" domain="[('account_type', 'in', ('cash', 'bank'))]" options="{'no_create': True}"/>
                            <field name="date"/>
                            <field name="reference"/>
                        </group>
					</group>

				</sheet>
				<footer>
					<button string="Create Transfer" type="object" name="action_create_transfer" class="btn-primary"/>
					<button string="Cancel" class="btn-secondary" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

</odoo>