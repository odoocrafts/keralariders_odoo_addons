<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_delivery_executive_tree" model="ir.ui.view">
        <field name="name">logistics.delivery.executive.tree</field>
        <field name="model">logistics.delivery.executive</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="mobile"/>
                <field name="vehicle_type"/>
                <field name="vehicle_number"/>
                <field name="assigned_region"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_delivery_executive_form" model="ir.ui.view">
        <field name="name">logistics.delivery.executive.form</field>
        <field name="model">logistics.delivery.executive</field>
        <field name="arch" type="xml">
            <form string="Delivery Executive">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- <button name="action_view_deliveries" type="object"
                                class="oe_stat_button" icon="fa-truck">
                            <field name="delivery_count" widget="statinfo" string="Deliveries"/>
                        </button> -->
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Executive Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="aadhaar_number"/>
                            <field name="driving_license"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Vehicle Details">
                            <field name="vehicle_type"/>
                            <field name="vehicle_number"/>
                            <field name="assigned_region"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="address" nolabel="1" placeholder="Full address..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_delivery_executive_search" model="ir.ui.view">
        <field name="name">logistics.delivery.executive.search</field>
        <field name="model">logistics.delivery.executive</field>
        <field name="arch" type="xml">
            <search string="Search Executives">
                <field name="name"/>
                <field name="mobile"/>
                <field name="assigned_region"/>
                <field name="vehicle_number"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Vehicle Type" name="group_vehicle" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Region" name="group_region" context="{'group_by': 'assigned_region'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_delivery_executive" model="ir.actions.act_window">
        <field name="name">Delivery Executives</field>
        <field name="res_model">logistics.delivery.executive</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a delivery executive
            </p>
            <p>Manage your delivery fleet and assign regions.</p>
        </field>
    </record>

    <menuitem id="menu_logistics_delivery_executive"
                name="Delivery Executives"
                parent="menu_logistics_root"
                action="action_delivery_executive"
                sequence="40"
    />
</odoo>