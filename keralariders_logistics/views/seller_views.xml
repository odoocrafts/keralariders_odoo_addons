<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_logistics_seller_tree" model="ir.ui.view">
        <field name="name">logistics.seller.list</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <list string="Sellers">
                <field name="partner_id" column_invisible="1"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <field name="tax_id"/>
                <field name="district_id"/>
            </list>
        </field>
    </record>

    <record id="view_logistics_seller_form" model="ir.ui.view">
        <field name="name">logistics.seller.form</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <form string="Seller">
                <header>
                    <button name="action_grant_portal_access" type="object" string="Grant Portal Access" class="btn-primary" invisible="not partner_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_wallets" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span>
                                    <field name="wallet_count" class="o_stat_value" widget="integer"/>
                                    |
                                    <field name="currency_id" invisible="1"/>
                                    <field name="total_wallet_balance" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-success="total_wallet_balance > 0" decoration-danger="total_wallet_balance &lt; 0"/>
                                </span>
                                <span class="o_stat_text">Wallets</span>
                            </div>
                        </button>
                        <button name="action_view_recharge_requests" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                Recharge Requests
                                <span class="o_stat_value">
                                    <field name="wallet_recharge_request_count"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Seller Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="partner_id" invisible="1"/>
                            <!-- <field name="name" string="Name" /> -->
                            <field name="email" />
                            <field name="phone" />
                        </group>
                        <group string="Address Information">
                            <field name="street" />
                            <field name="street2" />
                            <field name="zip" string="Pincode"/>
                            <field name="district_id" options="{'no_create': True}" />
                            <field name="city" />
                            <field name="country_id" options="{'no_create': True}" />
                            <field name="state_id" options="{'no_create': True}" />
                            <field name="tax_id" />
                        </group>

                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_logistics_seller_search" model="ir.ui.view">
        <field name="name">logistics.seller.search</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <search string="Search Sellers">

                <!-- Global Search -->
                <field name="name"
                    string="Seller"
                    filter_domain="[
                        '|','|','|','|','|',
                        ('name', 'ilike', self),
                        ('email', 'ilike', self),
                        ('phone', 'ilike', self),
                        ('zip', 'ilike', self),
                        ('tax_id', 'ilike', self),
                        ('city', 'ilike', self)
                    ]"/>

                <field name="district_id"/>
                <field name="state_id"/>
                <field name="country_id"/>


                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="District"
                            name="group_district"
                            context="{'group_by': 'district_id'}"/>

                    <filter string="State"
                            name="group_state"
                            context="{'group_by': 'state_id'}"/>

                    <filter string="Country"
                            name="group_country"
                            context="{'group_by': 'country_id'}"/>

                </group>

            </search>
        </field>
    </record>

    <record id="action_logistics_seller" model="ir.actions.act_window">
        <field name="name">Sellers</field>
        <field name="res_model">logistics.seller</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_seller_tree"/>
        <field name="search_view_id" ref="view_logistics_seller_search"/>
    </record>

    <menuitem id="menu_logistics_root" name="Logistics Management" web_icon="keralariders_logistics,static/description/icon.png"/>

    <menuitem id="menu_logistics_seller_root" parent="menu_logistics_root" name="Sellers" action="action_logistics_seller"/>
</odoo>