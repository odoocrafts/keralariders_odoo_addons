<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_logistics_seller_tree" model="ir.ui.view">
        <field name="name">logistics.seller.list</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <list string="Sellers">
                <field name="partner_id" column_invisible="1"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <field name="tax_id"/>
                <field name="district_id"/>
            </list>
        </field>
    </record>

    <record id="view_logistics_seller_form" model="ir.ui.view">
        <field name="name">logistics.seller.form</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <form string="Seller">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_wallets" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span>
                                    <field name="wallet_count" class="o_stat_value" widget="integer"/>
                                    |
                                    <field name="currency_id" invisible="1"/>
                                    <field name="total_wallet_balance" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Wallets</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Seller Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="partner_id" invisible="1"/>
                            <!-- <field name="name" string="Name" /> -->
                            <field name="email" />
                            <field name="phone" />
                        </group>
                        <group string="Address Information">
                            <field name="street" />
                            <field name="street2" />
                            <field name="zip" string="Pincode"/>
                            <field name="district_id" options="{'no_create': True}" />
                            <field name="city" />
                            <field name="country_id" options="{'no_create': True}" />
                            <field name="state_id" options="{'no_create': True}" />
                            <field name="tax_id" />
                        </group>

                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_logistics_seller_search" model="ir.ui.view">
        <field name="name">logistics.seller.search</field>
        <field name="model">logistics.seller</field>
        <field name="arch" type="xml">
            <search string="Seller Search">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <field name="tax_id"/>
                <field name="district_id"/>
                <filter string="With GSTIN" name="with_gstin" domain="[['tax_id','!=',False]]"/>
            </search>
        </field>
    </record>

    <record id="action_logistics_seller" model="ir.actions.act_window">
        <field name="name">Sellers</field>
        <field name="res_model">logistics.seller</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_seller_tree"/>
        <field name="search_view_id" ref="view_logistics_seller_search"/>
    </record>

    <menuitem id="menu_logistics_root" name="Logistics Management"/>

    <menuitem id="menu_logistics_seller_root" parent="menu_logistics_root" name="Sellers" action="action_logistics_seller"/>
</odoo>