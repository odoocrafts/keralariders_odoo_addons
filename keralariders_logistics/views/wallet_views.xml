<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_logistics_wallet_tree" model="ir.ui.view">
        <field name="name">logistics.wallet.list</field>
        <field name="model">logistics.wallet</field>
        <field name="arch" type="xml">
            <list string="Wallets">
                <field name="name"/>
                <field name="seller_id"/>
                <field name="balance" widget="monetary" options="{'currency_field': 'currency_id', 'fg_color': 'red: balance &lt; 0; green: balance >= 0'}"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_logistics_wallet_form" model="ir.ui.view">
        <field name="name">logistics.wallet.form</field>
        <field name="model">logistics.wallet</field>
        <field name="arch" type="xml">
            <form string="Wallet">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transactions" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span>
                                    <field name="currency_id" invisible="1"/>
                                    <i class="fa fa-arrow-down" style="color:green;margin-right:4px;"/>
                                    <field name="total_credit" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <i class="fa fa-arrow-up" style="color:red;margin:0 4px;"/>
                                    <field name="total_debit" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Transactions</span>
                            </div>
                        </button>
                        <button name="action_view_recharge_requests" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                Recharge Requests
                                <span class="o_stat_value">
                                    <field name="wallet_recharge_request_count"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <group string="Wallet Information">
                        <field name="seller_id" options="{'no_create': True}"/>
                        <field name="name"/>
                        <field name="balance" widget="monetary" decoration-success="balance > 0" decoration-danger="balance &lt; 0"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_logistics_wallet_search" model="ir.ui.view">
        <field name="name">logistics.wallet.search</field>
        <field name="model">logistics.wallet</field>
        <field name="arch" type="xml">
            <search string="Search Wallets">

                <!-- Global Search -->
                <field name="name"
                    string="Wallet"
                    filter_domain="[
                        '|',
                        ('name', 'ilike', self),
                        ('seller_id.name', 'ilike', self)
                    ]"/>

                <field name="seller_id"/>

                <separator/>

                <!-- Quick Filters -->

                <filter name="has_transactions"
                        string="Has Transactions"
                        domain="[('transaction_ids', '!=', False)]"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="Seller"
                            name="group_seller"
                            context="{'group_by': 'seller_id'}"/>

                </group>

            </search>
        </field>
    </record>

    <record id="action_logistics_wallet" model="ir.actions.act_window">
        <field name="name">Wallets</field>
        <field name="res_model">logistics.wallet</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_wallet_tree"/>
        <field name="search_view_id" ref="view_logistics_wallet_search"/>
    </record>

    <!-- Wallet Transaction Views and Actions -->
    <record id="view_logistics_wallet_transaction_tree" model="ir.ui.view">
        <field name="name">logistics.wallet.transaction.list</field>
        <field name="model">logistics.wallet.transaction</field>
        <field name="arch" type="xml">
            <list string="Wallet Transactions" editable="bottom" delete="1">
                <field name="transaction_date" width="100"/>
                <field name="wallet_id" width="100"/>
                <field name="amount" width="100" string="Amount" sum="Amount" options='{"fg_color": "red: amount &lt; 0; green: amount >= 0"}'/>
                <field name="reference" width="100"/>
                <field name="transaction_type" width="100"/>
                <field name="currency_id" column_invisible="1"/>

            </list>
        </field>
    </record>

    <record id="view_logistics_wallet_transaction_form" model="ir.ui.view">
        <field name="name">logistics.wallet.transaction.form</field>
        <field name="model">logistics.wallet.transaction</field>
        <field name="arch" type="xml">
            <form string="Wallet Transaction">
                <sheet>
                    <group>
                        <field name="wallet_id"/>
                        <field name="transaction_date"/>
                        <field name="transaction_type"/>
                        <field name="amount"/>
                        <field name="reference"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_logistics_wallet_transaction_search" model="ir.ui.view">
        <field name="name">logistics.wallet.transaction.search</field>
        <field name="model">logistics.wallet.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Wallet Transactions">

                <!-- Global Search -->
                <field name="wallet_id"
                    string="Search"
                    filter_domain="[
                        '|','|','|',
                        ('wallet_id.name', 'ilike', self),
                        ('wallet_id.seller_id.name', 'ilike', self),
                        ('reference', 'ilike', self),
                        ('description', 'ilike', self)
                    ]"/>

                <field name="wallet_id"/>
                <field name="shipment_id"/>
                <field name="recharge_request_id"/>
                <field name="transaction_date"/>

                <separator/>

                <!-- Transaction Type -->
                <filter name="credit"
                        string="Credits"
                        domain="[('transaction_type', '=', 'credit')]"/>

                <filter name="debit"
                        string="Debits"
                        domain="[('transaction_type', '=', 'debit')]"/>

                <separator/>

                <!-- Related Records -->
                <filter name="shipment_transactions"
                        string="Shipment Transactions"
                        domain="[('shipment_id', '!=', False)]"/>

                <filter name="recharge_transactions"
                        string="Recharge Transactions"
                        domain="[('recharge_request_id', '!=', False)]"/>

                <separator/>

                <!-- Date -->
                <filter name="today"
                        string="Today"
                        domain="[('transaction_date', '=', context_today())]"/>

                <filter name="month"
                        string="Month"
                        date="transaction_date"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="Wallet"
                            name="group_wallet"
                            context="{'group_by': 'wallet_id'}"/>
<!-- 
                    <filter string="Seller"
                            name="group_seller"
                            context="{'group_by': 'wallet_id.seller_id'}"/> -->

                    <filter string="Transaction Type"
                            name="group_type"
                            context="{'group_by': 'transaction_type'}"/>

                    <filter string="Transaction Date"
                            name="group_date"
                            context="{'group_by': 'transaction_date'}"/>

                </group>

            </search>
        </field>
    </record>

    <record id="action_logistics_wallet_transaction" model="ir.actions.act_window">
        <field name="name">Wallet Transactions</field>
        <field name="res_model">logistics.wallet.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_wallet_transaction_tree"/>
        <field name="search_view_id" ref="view_logistics_wallet_transaction_search"/>
    </record>

    <menuitem id="menu_logistics_wallet"
                name="Wallets"
                parent="menu_logistics_root"
                sequence="10"
    />
    <menuitem id="menu_logistics_wallet_wallet"
                name="Wallets"
                parent="menu_logistics_wallet"
                action="action_logistics_wallet"
                sequence="10"
    />
    <menuitem id="menu_wallet_transactions"
              name="Wallet Transactions"
              parent="menu_logistics_wallet"
              action="action_logistics_wallet_transaction"
              sequence="20"/>


</odoo>