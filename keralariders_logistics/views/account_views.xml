<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_logistics_account_tree" model="ir.ui.view">
        <field name="name">logistics.account.list</field>
        <field name="model">logistics.account</field>
        <field name="arch" type="xml">
            <list string="Bank/Cash Account">
                <field name="name"/>
                <field name="account_type"/>
                <field name="reference"/>
                <field name="balance" widget="monetary" options="{'currency_field': 'currency_id', 'fg_color': 'red: balance &lt; 0; green: balance >= 0'}"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_logistics_account_search" model="ir.ui.view">
        <field name="name">logistics.account.search</field>
        <field name="model">logistics.account</field>
        <field name="arch" type="xml">
            <search string="Search Accounts">

                <!-- Global Search -->
                <field name="name"
                    string="Account"
                    filter_domain="[
                        '|',
                        ('name', 'ilike', self),
                        ('reference', 'ilike', self)
                    ]"/>

                <separator/>

                <!-- Account Type -->
                <filter name="bank"
                        string="Bank Accounts"
                        domain="[('account_type', '=', 'bank')]"/>

                <filter name="cash"
                        string="Cash Accounts"
                        domain="[('account_type', '=', 'cash')]"/>

                <filter name="cod_customer"
                        string="COD Customer Accounts"
                        domain="[('account_type', '=', 'cod_customer')]"/>

                <filter name="seller"
                        string="Seller Accounts"
                        domain="[('account_type', '=', 'seller')]"/>

                <separator/>

                <!-- Related Records -->
                <filter name="has_transactions"
                        string="Has Transactions"
                        domain="[('transaction_ids', '!=', False)]"/>

                <!-- Group By -->
                <group>

                    <filter string="Account Type"
                            name="group_account_type"
                            context="{'group_by': 'account_type'}"/>

                </group>

            </search>
        </field>
    </record>

    <record id="view_logistics_account_form" model="ir.ui.view">
        <field name="name">logistics.account.form</field>
        <field name="model">logistics.account</field>
        <field name="arch" type="xml">
            <form string="Bank/Cash Account">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transfers" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                Transfers
                                <span class="o_stat_value">
                                    <field name="transfer_count"/>
                                </span>
                            </div>
                        </button>
                        <button name="action_view_transactions" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span>
                                    <field name="currency_id" invisible="1"/>
                                    <i class="fa fa-arrow-down" style="color:green;margin-right:4px;"/>
                                    <field name="total_credit" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <i class="fa fa-arrow-up" style="color:red;margin:0 4px;"/>
                                    <field name="total_debit" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Transactions</span>
                            </div>
                        </button>
                    </div>
                    <group string="Account Information">
                        <field name="name"/>
                        <field name="account_type"/>
                        <field name="reference"/>
                        <field name="balance" widget="monetary" decoration-success="balance > 0" decoration-danger="balance &lt; 0"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Account Transaction Views and Actions -->
    <record id="view_logistics_account_transfer_tree" model="ir.ui.view">
        <field name="name">logistics.account.transfer.list</field>
        <field name="model">logistics.account.transfer</field>
        <field name="arch" type="xml">
            <list string="Account Transfers">
                <field name="transfer_date" width="100" string="Date"/>
                <field name="name" width="100" options='{"bg_color": "#e1fade: cod_clearance_transfer_id != False; #fffad6: not cod_clearance_transfer_id;  #d2c5ed: transfer_type!=&apos;cod_payment&apos;;"}'/>              
                <field name="transfer_type" widget="badge" width="100"/>
                <field name="related_seller_id" width="100"/>
                <field name="shipment_id" width="100"/>
                <field name="from_account_id" width="100"/>
                <field name="to_account_id" width="100"/>
                <field name="cod_clearance_transfer_id" column_invisible="1" width="100"/>
                <field name="amount" width="100" string="Amount" sum="Amount" 
                    options='{"bg_color": "#e4ede4: cod_clearance_transfer_id != False;"}'/>
                <field name="reference" width="100" string="Transfer Ref"/>
                <field name="currency_id" column_invisible="1"/>

            </list>
        </field>
    </record>

    <record id="view_logistics_account_transfer_form" model="ir.ui.view">
        <field name="name">logistics.account.transfer.form</field>
        <field name="model">logistics.account.transfer</field>
        <field name="arch" type="xml">
            <form string="Account Transfer">
                <sheet>
                    <div class="oe_title" >
                        <h1 class="text-primary">
                            <field name="name" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>

                            <field name="id" invisible="1"/>
                            <field name="transfer_date"/>
                            <field name="transfer_type" readonly="1" force_save="1"/>
                            <field name="from_account_id"/>
                            <field name="to_account_id"/>
                            <field name="amount" string="Amount" sum="Amount"/>
                            <field name="reference"/>
                            <field name="related_seller_id"/>
                            <field name="shipment_id" invisible="transfer_type == 'cod_clearance'"/>
                            <field name="cod_clearance_transfer_id" invisible="not cod_clearance_transfer_id" readonly="1" force_save="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions">
                            <field name="transaction_ids" force_save="1">
                            </field>
                        </page>
                        <page string="Cleared COD Transfers" invisible='transfer_type != "cod_clearance"'>
                            <field name="cod_clearance_payment_transfer_ids" force_save="1" domain="[('cod_clearance_transfer_id', '=', False), ('id', '!=', id), ('transfer_type', '=', 'cod_payment'), ('to_account_id', '=', from_account_id)]"></field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_logistics_account_transfer_search" model="ir.ui.view">
        <field name="name">logistics.account.transfer.search</field>
        <field name="model">logistics.account.transfer</field>
        <field name="arch" type="xml">
            <search string="Search Account Transfers">

                <!-- Global Search -->
                <field name="name"
                    string="Search"
                    filter_domain="[
                        '|','|','|','|','|',
                        ('name', 'ilike', self),
                        ('reference', 'ilike', self),
                        ('description', 'ilike', self),
                        ('from_account_id.name', 'ilike', self),
                        ('to_account_id.name', 'ilike', self),
                        ('related_seller_id.name', 'ilike', self)
                    ]"/>

                <field name="from_account_id"/>
                <field name="to_account_id"/>
                <field name="related_seller_id"/>
                <field name="shipment_id"/>
                <field name="transfer_date"/>

                <separator/>

                <!-- Related Records -->

                <separator/>

                <!-- Date -->
                <filter name="today"
                        string="Today"
                        domain="[('transfer_date', '=', context_today())]"/>

                <filter name="month"
                        string="Month"
                        date="transfer_date"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="Transfer Type"
                            name="group_transfer_type"
                            context="{'group_by': 'transfer_type'}"/>

                    <filter string="From Account"
                            name="group_from_account"
                            context="{'group_by': 'from_account_id'}"/>

                    <filter string="To Account"
                            name="group_to_account"
                            context="{'group_by': 'to_account_id'}"/>

                    <filter string="Related Seller"
                            name="group_seller"
                            context="{'group_by': 'related_seller_id'}"/>

                    <filter string="Transfer Date"
                            name="group_transfer_date"
                            context="{'group_by': 'transfer_date'}"/>

                </group>

            </search>
        </field>
    </record>

    <!-- Search View for COD Payment Transfers Only -->
    <record id="view_logistics_account_transfer_cod_payment_search" model="ir.ui.view">
        <field name="name">logistics.account.transfer.cod.payment.search</field>
        <field name="model">logistics.account.transfer</field>
        <field name="arch" type="xml">
            <search string="Search COD Payment Transfers">

                <!-- Global Search -->
                <field name="name"
                    string="Search"
                    filter_domain="[
                        '|','|','|','|','|',
                        ('name', 'ilike', self),
                        ('reference', 'ilike', self),
                        ('description', 'ilike', self),
                        ('from_account_id.name', 'ilike', self),
                        ('to_account_id.name', 'ilike', self),
                        ('related_seller_id.name', 'ilike', self)
                    ]"/>

                <field name="from_account_id"/>
                <field name="to_account_id"/>
                <field name="related_seller_id"/>
                <field name="shipment_id"/>

                <separator/>

                <!-- Related Records -->

                <filter name="cleared"
                        string="Cleared"
                        domain="[('cod_clearance_transfer_id', '!=', False)]"/>

                <filter name="not_cleared"
                        string="Not Cleared"
                        domain="[('cod_clearance_transfer_id', '=', False)]"/>

                <separator/>

                <!-- Date -->
                <filter name="today"
                        string="Today"
                        domain="[('transfer_date', '=', context_today())]"/>

                <filter name="month"
                        string="Month"
                        date="transfer_date"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="From Account"
                            name="group_from_account"
                            context="{'group_by': 'from_account_id'}"/>

                    <filter string="To Account"
                            name="group_to_account"
                            context="{'group_by': 'to_account_id'}"/>

                    <filter string="Related Seller"
                            name="group_seller"
                            context="{'group_by': 'related_seller_id'}"/>

                    <filter string="Related Shipment"
                            name="group_shipment"
                            context="{'group_by': 'shipment_id'}"/>

                    <filter string="Transfer Date"
                            name="group_transfer_date"
                            context="{'group_by': 'transfer_date'}"/>
                </group>

            </search>
        </field>
    </record>

    <record id="view_logistics_account_transaction_tree" model="ir.ui.view">
        <field name="name">logistics.account.transaction.list</field>
        <field name="model">logistics.account.transaction</field>
        <field name="arch" type="xml">
            <list string="Account Transactions" delete="0" create="0" edit="0">
                <field name="transaction_date" width="100"/>
                <field name="account_id" width="100"/>
                <field name="amount" width="100" string="Amount" sum="Amount" options='{"fg_color": "red: amount &lt; 0; green: amount >= 0"}'/>
                <field name="transaction_type" width="100" />
                <field name="reference" width="100"/>
                <field name="currency_id" column_invisible="1"/>

            </list>
        </field>
    </record>

    <record id="view_logistics_account_transaction_search" model="ir.ui.view">
        <field name="name">logistics.account.transaction.search</field>
        <field name="model">logistics.account.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Account Transactions">

                <!-- Global Search -->
                <field name="account_id"
                    string="Transaction"
                    filter_domain="[
                        '|','|','|','|',
                        ('account_id.name', 'ilike', self),
                        ('reference', 'ilike', self),
                        ('description', 'ilike', self),
                        ('transfer_id.name', 'ilike', self),
                        ('transfer_id.related_seller_id.name', 'ilike', self)
                    ]"/>

                <field name="account_id"/>
                <field name="transfer_id"/>
                <field name="transaction_date"/>

                <separator/>

                <!-- Transaction Type -->
                <filter name="credit"
                        string="Credits"
                        domain="[('transaction_type', '=', 'credit')]"/>

                <filter name="debit"
                        string="Debits"
                        domain="[('transaction_type', '=', 'debit')]"/>

                <separator/>

                <!-- Related Transfer -->
                <filter name="cod_payment"
                        string="COD Payments"
                        domain="[('transfer_id.transfer_type', '=', 'cod_payment')]"/>

                <filter name="cod_clearance"
                        string="COD Clearances"
                        domain="[('transfer_id.transfer_type', '=', 'cod_clearance')]"/>

                <filter name="other_transfer"
                        string="Other Transfers"
                        domain="[('transfer_id.transfer_type', '=', 'other')]"/>

                <separator/>

                <!-- Date -->
                <filter name="today"
                        string="Today"
                        domain="[('transaction_date', '=', context_today())]"/>

                <filter name="month"
                        string="Month"
                        date="transaction_date"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="Account"
                            name="group_account"
                            context="{'group_by': 'account_id'}"/>

                    <filter string="Transaction Type"
                            name="group_transaction_type"
                            context="{'group_by': 'transaction_type'}"/>

                    <filter string="Transaction Date"
                            name="group_transaction_date"
                            context="{'group_by': 'transaction_date'}"/>

                </group>

            </search>
        </field>
    </record>

    <record id="action_logistics_account" model="ir.actions.act_window">
        <field name="name">Bank/Cash Accounts</field>
        <field name="res_model">logistics.account</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_account_tree"/>
        <!-- <field name="search_view_id" ref="view_logistics_account_search"/> -->
    </record>


    <record id="action_logistics_account_transfer_cod_payment" model="ir.actions.act_window">
        <field name="name">COD Payment Transfers</field>
        <field name="res_model">logistics.account.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_account_transfer_tree"/>
        <field name="domain">[('transfer_type', '=', 'cod_payment')]</field>
        <field name="context">{'default_transfer_type': 'cod_payment'}</field>
        <field name="search_view_id" ref="view_logistics_account_transfer_cod_payment_search"/>
    </record>

    <record id="action_logistics_account_transfer_cod_clearance" model="ir.actions.act_window">
        <field name="name">COD Clearance Transfers</field>
        <field name="res_model">logistics.account.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_account_transfer_tree"/>
        <field name="domain">[('transfer_type', '=', 'cod_clearance')]</field>
        <field name="context">{'default_transfer_type': 'cod_clearance'}</field>
        <field name="search_view_id" ref="view_logistics_account_transfer_search"/>
    </record>

    <record id="action_logistics_account_transfer_other" model="ir.actions.act_window">
        <field name="name">Other Transfers</field>
        <field name="res_model">logistics.account.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_logistics_account_transfer_tree"/>
        <field name="domain">[('transfer_type', '=', 'other')]</field>
        <field name="context">{'default_transfer_type': 'other'}</field>
        <field name="search_view_id" ref="view_logistics_account_transfer_search"/>
    </record>


    <record id="action_logistics_account_transaction" model="ir.actions.act_window">
        <field name="name">Account Transactions</field>
        <field name="res_model">logistics.account.transaction</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_logistics_account_transaction_tree"/>
        <!-- <field name="search_view_id" ref="view_logistics_account_transaction_search"/> -->
    </record>

    <menuitem id="menu_logistics_account"
                name="Bank/Cash Accounts"
                parent="menu_logistics_root"
                sequence="70"
    />
    <menuitem id="menu_logistics_account_account"
                name="Accounts"
                parent="menu_logistics_account"
                action="action_logistics_account"
                sequence="10"
    />
    <menuitem id="menu_logistics_account_transfers"
                name="Account Transfers"
                parent="menu_logistics_root"
                sequence="60"
    />
    <menuitem id="menu_logistics_account_transfer_cod_payment"
                name="COD Payment Transfers"
                parent="menu_logistics_account_transfers"
                sequence="10"
                action="action_logistics_account_transfer_cod_payment"
    />
    <menuitem id="menu_logistics_account_transfer_cod_clearance"
                name="COD Clearance Transfers"
                parent="menu_logistics_account_transfers"
                sequence="20"
                action="action_logistics_account_transfer_cod_clearance"
    />
    <menuitem id="menu_logistics_account_transfer_other"
                name="Other Transfers"
                parent="menu_logistics_account_transfers"
                sequence="30"
                action="action_logistics_account_transfer_other"
    />
    <menuitem id="menu_logistics_account_transaction"
                name="All Transactions"
                parent="menu_logistics_account"
                action="action_logistics_account_transaction"
                sequence="30"
    />

</odoo>