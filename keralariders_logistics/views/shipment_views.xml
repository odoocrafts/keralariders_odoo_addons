<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Shipment Search View -->
    <record id="view_logistics_shipment_search" model="ir.ui.view">
        <field name="name">logistics.shipment.search</field>
        <field name="model">logistics.shipment</field>
        <field name="arch" type="xml">
            <search string="Search Shipments">

                <!-- Search -->
                <field name="name"/>
                <field name="seller_id"/>
                <field name="shipping_to_name"/>
                <field name="shipping_to_mobile"/>
                <field name="shipping_to_email"/>
                <field name="delivery_executive_id"/>

                <separator/>

                <!-- Quick Filters -->
                <filter name="my_shipments"
                        string="My Shipments"
                        domain="[('create_uid', '=', uid)]"/>

                <filter name="wallet_added"
                        string="Wallet Deducted"
                        domain="[('wallet_transaction_id', '!=', False)]"/>

                <filter name="cod_orders"
                        string="COD Orders"
                        domain="[('order_payment_type', '=', 'cod')]"/>

                <filter name="prepaid_orders"
                        string="Prepaid Orders"
                        domain="[('order_payment_type', '=', 'prepaid')]"/>

                <separator/>

                <!-- Delivery Status -->
                <filter name="order_added"
                        string="Order Added"
                        domain="[('state', '=', 'order_added')]"/>

                <filter name="pickup_requested"
                        string="Pickup Requested"
                        domain="[('state', '=', 'pickup_requested')]"/>

                <filter name="picked"
                        string="Picked"
                        domain="[('state', '=', 'picked')]"/>

                <filter name="in_transit"
                        string="In Transit"
                        domain="[('state', '=', 'in_transit')]"/>

                <filter name="delivered"
                        string="Delivered"
                        domain="[('state', '=', 'delivered')]"/>

                <filter name="return_requested"
                        string="Return Requested"
                        domain="[('state', '=', 'return_requested')]"/>

                <filter name="return_picked"
                        string="Return Picked"
                        domain="[('state', '=', 'return_picked')]"/>

                <filter name="returned"
                        string="Returned"
                        domain="[('state', '=', 'returned')]"/>

                <filter name="cancelled"
                        string="Cancelled"
                        domain="[('state', 'in', ('cancelled', 'cancel'))]"/>

                <separator/>

                <!-- Date Filters -->
                <filter name="today"
                        string="Today"
                        domain="[('order_date', '=', context_today())]"/>

                <filter string="This Week" name="this_week"

                domain="[('order_date', '&lt;=', ((context_today()+relativedelta(weeks=0, weekday=-1)).strftime('%Y-%m-%d'))), 

                ('order_date', '&gt;=', ((context_today()-relativedelta(weeks=1, weekday=0)).strftime('%Y-%m-%d')))]"/>
                <filter name="month"
                        string="Month"
                        date="order_date"/>

                <separator/>

                <!-- Group By -->
                <group>

                    <filter string="Seller"
                            name="group_seller"
                            context="{'group_by':'seller_id'}"/>

                    <filter string="Delivery Executive"
                            name="group_delivery_executive"
                            context="{'group_by':'delivery_executive_id'}"/>

                    <filter string="Status"
                            name="group_state"
                            context="{'group_by':'state'}"/>

                    <filter string="Payment Type"
                            name="group_payment"
                            context="{'group_by':'order_payment_type'}"/>

                    <filter string="Order Date"
                            name="group_order_date"
                            context="{'group_by':'order_date'}"/>

                    <filter string="From District"
                            name="group_from_district"
                            context="{'group_by':'shipping_from_district_id'}"/>

                    <filter string="To District"
                            name="group_to_district"
                            context="{'group_by':'shipping_to_district_id'}"/>

                </group>

            </search>
        </field>
    </record>

    <!-- Shipment List View -->
    <record id="view_shipment_list" model="ir.ui.view">
        <field name="name">Shipment List</field>
        <field name="model">logistics.shipment</field>
        <field name="arch" type="xml">
            <list string="Shipments">
                <field name="name" string="Reference No." width="100"/>
                <field name="seller_id" width="100"/>
                <field name="delivery_executive_id" string="Delivery Exec." width="100"/>
                <field name="order_date" width="100"/>
                <field name="shipping_from_district_id" string="Shipping From" width="100"/>
                <field name="shipping_to_district_id" string="Shipping To" width="100"/>
                <field name="order_payment_type" string="Payment Type" width="100"/>
                <field name="state" widget="badge"
                    decoration-info="state in ('order_added', 'return_picked')"
                    decoration-warning="state in ('pickup_requested','return_requested')"
                    decoration-primary="state == 'picked'"
                    decoration-muted="state == 'in_transit'"
                    decoration-success="state == 'delivered'"
                    decoration-danger="state in ('cancelled', 'cancel')"
                    width="100"
                />                
                <field name="cod_amount" string="COD Amount" width="100" sum="COD Amount" invisible="order_payment_type != 'cod'" options="{'fg_color': 'brown: cod_balance_amount > 0; green: cod_balance_amount &lt;=0 ;'}"/>
                <field name="cod_balance_amount" string="COD Balance Amount" optional="hide" width="100" sum="COD Amount" invisible="order_payment_type != 'cod'"/>
                <field name="estimated_delivery_date" string="Est. Del Date" width="100"/>
                <field name="delivery_charges_total" string="Delivery Charge" width="100" sum="Delivery Charges" options="{'fg_color': 'brown: not wallet_transaction_id; green: wallet_transaction_id;'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="wallet_transaction_id" column_invisible="1"/>
                <button name="%(keralariders_logistics.action_report_shipment)d" class="oe_highlight" string="Print AWB" type="action" icon="fa-print" width="100"/>
            </list>
        </field>
    </record>

    <!-- Shipment Form View -->
    <record id="view_shipment_form" model="ir.ui.view">
        <field name="name">Shipment Form</field>
        <field name="model">logistics.shipment</field>
        <field name="arch" type="xml">
            <form string="Shipment">
                <header>
                    <button name="%(keralariders_logistics.action_report_shipment)d" string="Print AWB" type="action" class="btn-primary"/>
                    <field name="state" widget="statusbar" options="{'clickable':1}"/>
                </header>
                <sheet>
                    <div class="oe_title" >
                        <h1 class="text-info">
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Info">
                            <field name="seller_id" required="1"/>
                            <field name="delivery_executive_id"/>
                            <field name="order_date"/>
                            <field name="order_payment_type"/>
                            <!-- <field name="cod_amount" invisible="order_payment_type != 'cod'"/> -->
                            <label for="cod_amount" invisible="order_payment_type != 'cod'"/>
                            <div class="d-flex align-items-center" invisible="order_payment_type != 'cod'">
                                <field name="cod_amount"
                                    class="oe_inline me-2"
                                    force_save="1"/>

                                <i class="fa fa-check-circle text-success me-2"
                                invisible="cod_balance_amount > 0"/>

                                <button name="action_add_cod_payment_transfer"
                                        type="object"
                                        class="btn btn-info btn-sm me-1"
                                        icon="fa-credit-card"
                                        string="Add Payment"
                                        invisible="cod_balance_amount &lt;= 0"/>
                                <button name="action_view_cod_payment_transfers"
                                        type="object"
                                        class="btn btn-primary btn-sm"
                                        icon="fa-eye"
                                        string="View Transfers"
                                        invisible="not cod_payment_transfer_ids"/>
                            </div>
                            <field name="cod_paid_amount" invisible="order_payment_type != 'cod'" readonly="1" force_save="1"/>
                            <field name="cod_balance_amount" invisible="order_payment_type != 'cod'" readonly="1" force_save="1"/>
                            <field name="cod_payment_transfer_ids" widget="many2many_tags" invisible="1"/>
                            <field name="tracking_url" widget="url"/>

                        </group>
                        <group string="Delivery Charges">
                            <field name="currency_id" invisible="1"/>
                            <field name="total_weight"/>
                            <field name="delivery_charges_subtotal"/>
                            <field name="tax_percentage" widget="percentage" string="Tax (GST) %" invisible="1"/>
                            
                            <!-- <label for="delivery_charges_total"/> -->
                            <label for="delivery_charges_total"/>
                            <div class="d-flex align-items-center">
                                <field name="delivery_charges_total"
                                    class="oe_inline me-2"
                                    force_save="1"/>

                                <i class="fa fa-check-circle text-success me-2"
                                invisible="not wallet_transaction_id"/>

                                <button name="action_add_wallet_transaction"
                                        type="object"
                                        class="btn btn-warning btn-sm me-1"
                                        icon="fa-credit-card"
                                        string="Deduct from Wallet"
                                        invisible="wallet_transaction_id"/>

                                <button name="action_view_wallet_transaction"
                                        type="object"
                                        class="btn btn-primary btn-sm"
                                        icon="fa-eye"
                                        string="View Transaction"
                                        invisible="not wallet_transaction_id"/>

                                <button name="delete_wallet_transaction"
                                        type="object"
                                        string="Remove Transaction"
                                        class="btn btn-danger btn-sm"
                                        icon="fa-trash"
                                        confirm="This will delete the wallet transaction and restore the wallet balance. Continue?"
                                        invisible="not wallet_transaction_id"/>
                            </div>
                        </group>
                    </group>
                    <group string="Products &amp; Item Details">
                        <field name="item_description"/>
                        <field name="total_order_value"/>
                        <field name="seller_notes"/>
                    </group>

                    <group>
                        <group string="Shipping From (Seller)">
                            <field name="shipping_from_name" string="Name"/>
                            <field name="shipping_from_address" string="Address"/>
                            <field name="shipping_from_zip" string="Pincode"/>
                            <field name="shipping_from_district_id" string="District"/>
                            <field name="shipping_from_state_id" string="State"/>
                            <field name="shipping_from_country_id" string="Country"/>
                        </group>
                        <group string="Shipping To (Customer)">
                            <field name="shipping_to_name" string="Name"/>
                            <field name="shipping_to_address" string="Address"/>
                            <field name="shipping_to_zip" string="Pincode"/>
                            <field name="shipping_to_district_id" string="District"/>
                            <field name="shipping_to_state_id" string="State"/>
                            <field name="shipping_to_country_id" string="Country"/>
                            <field name="shipping_to_mobile" string="Mobile"/>
                            <field name="shipping_to_email" string="Email"/>
                        </group>
                    </group>
                    <group string="Billing Address">
                        <group>
                            <field name="billing_name" string="Name"/>
                            <field name="billing_address" string="Address"/>
                            <field name="billing_zip" string="Pincode"/>
                            <field name="billing_district_id" string="District"/>
                            <field name="billing_state_id" string="State"/>
                            <field name="billing_country_id" string="Country"/>
                        </group>
                    </group>
                    <group string="Delivery">
                        <field name="estimated_delivery_date"/>
                        <field name="actual_delivery_date"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Shipment Window Action -->
    <record id="action_shipment" model="ir.actions.act_window">
        <field name="name">Shipments</field>
        <field name="res_model">logistics.shipment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_logistics_shipment_search"/>
        <field name="context">{'search_default_this_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new shipment
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_shipment" name="Shipments" action="action_shipment" parent="menu_logistics_root" sequence="5"/>

</odoo>