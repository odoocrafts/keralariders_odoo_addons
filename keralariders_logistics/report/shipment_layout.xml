<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="paperformat_shipping_label" model="report.paperformat">
        <field name="name">Shipping Label Paperformat</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10.00</field>
        <field name="margin_left">4.0</field>
        <field name="margin_right">4.0</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">10</field>
        <field name="dpi">90</field>
    </record>

    <template id="report_shipment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="company" t-value="o.company_id" />
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 12px; color: black;">
                        
                        <table style="width: 100%; border-collapse: collapse; border: 2px solid black;">
                            <!-- HEADER -->
                            <tr>
                                <td style="width: 50%; border: 2px solid black; padding: 15px; text-align: center; vertical-align: middle;">
                                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 60px; max-width: 100%;" alt="Logo"/>
                                </td>
                                <td style="width: 50%; border: 2px solid black; padding: 15px; text-align: center; vertical-align: middle;">
                                    <h2 style="margin: 0; font-size: 26px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase;">
                                        <span t-field="company.name"/>
                                    </h2>
                                </td>
                            </tr>
                            
                            <!-- QR CODE AND AWB -->
                            <tr>
                                <td colspan="2" style="border: 2px solid black; padding: 20px; text-align: center;">
                                    <div style="margin: 0 auto; display: inline-block;">
                                        <img t-att-src="'/report/barcode/QR/%s?width=150&amp;height=150' % o.tracking_url" style="width: 150px; height: 150px;" alt="QR Code"/>
                                    </div>
                                    <h2 style="margin: 10px 0 0 0; font-size: 24px; font-weight: 900; letter-spacing: 2px;">
                                        AWB: <span t-field="o.name"/>
                                    </h2>
                                    <div style="font-size: 16px; font-weight: bold; margin-top: 5px; text-transform: uppercase;">
                                        <span t-field="o.shipping_to_district_id"/> <span t-if="o.shipping_to_state_id" t-esc="'/ ' + o.shipping_to_state_id.name"/>
                                    </div>
                                </td>
                            </tr>
                            
                            <!-- SHIP TO & PAYMENT TYPE -->
                            <tr>
                                <td style="width: 70%; border: 2px solid black; padding: 15px; vertical-align: top;">
                                    <div style="font-size: 14px; font-weight: bold; margin-bottom: 5px;">Ship To:</div>
                                    <div style="font-size: 18px; font-weight: 900; text-transform: uppercase;" t-field="o.shipping_to_name"/>
                                    <div style="font-size: 14px; margin-top: 3px;">
                                        <span t-field="o.shipping_to_address"/>
                                    </div>
                                    <div style="font-size: 14px;">
                                        <span t-field="o.shipping_to_district_id"/>, <span t-field="o.shipping_to_state_id"/>
                                    </div>
                                    <div style="font-size: 16px; font-weight: bold; margin-top: 8px;">
                                        PIN: <span t-field="o.shipping_to_zip"/>
                                    </div>
                                    <div style="font-size: 14px; font-weight: bold; margin-top: 5px;">
                                        Mobile: <span t-field="o.shipping_to_mobile"/>
                                    </div>
                                </td>
                                <td style="width: 30%; border: 2px solid black; padding: 15px; text-align: center; vertical-align: middle;">
                                    <t t-if="o.order_payment_type == 'cod'">
                                        <div style="font-size: 32px; font-weight: 900; border: 4px solid black; padding: 10px; display: inline-block;">COD</div>
                                        <div style="font-size: 20px; font-weight: bold; margin-top: 15px;">
                                            <span t-field="o.cod_amount"/>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div style="font-size: 28px; font-weight: 900; letter-spacing: 1px;">PRE-PAID</div>
                                    </t>
                                </td>
                            </tr>
                            
                            <!-- SELLER AND DATE -->
                            <tr>
                                <td style="width: 70%; border: 2px solid black; padding: 10px 15px; vertical-align: top;">
                                    <div style="font-weight: bold; font-size: 14px; margin-bottom: 2px;">Seller: <span t-field="o.shipping_from_name"/></div>
                                    <div style="font-size: 12px; margin-top: 2px;">
                                        <span t-field="o.shipping_from_address"/>, 
                                        <span t-field="o.shipping_from_district_id"/>, 
                                        <span t-field="o.shipping_from_state_id"/> - <span t-field="o.shipping_from_zip"/>
                                    </div>
                                </td>
                                <td style="width: 30%; border: 2px solid black; padding: 10px 15px; vertical-align: top;">
                                    <div style="font-weight: bold; font-size: 14px;">Date:</div>
                                    <div style="font-size: 14px; margin-bottom: 10px;" t-field="o.order_date" t-options="{'widget': 'date'}"/>
                                    
                                    <div style="font-weight: bold; font-size: 14px;">Weight:</div>
                                    <div style="font-size: 14px;"><span t-field="o.total_weight"/> Kg</div>
                                </td>
                            </tr>
                            
                            <!-- PRODUCT DETAILS -->
                            <tr>
                                <td colspan="2" style="border: 2px solid black; padding: 0;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <th style="border-right: 2px solid black; border-bottom: 2px solid black; padding: 10px 15px; text-align: left; font-size: 14px;">Product Description</th>
                                            <th style="border-bottom: 2px solid black; padding: 10px 15px; text-align: right; width: 30%; font-size: 14px;">Value</th>
                                        </tr>
                                        <tr>
                                            <td style="border-right: 2px solid black; padding: 15px; vertical-align: top; font-size: 14px;">
                                                <span t-field="o.item_description"/>
                                            </td>
                                            <td style="padding: 15px; text-align: right; vertical-align: top; font-size: 14px; font-weight: bold;">
                                                <span t-field="o.total_order_value"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            
                        </table>
                        
                        <t t-if="o.seller_notes">
                            <div style="border: 2px solid black; border-top: none; padding: 10px 15px; font-size: 12px;">
                                <b>Notes:</b> <span t-field="o.seller_notes"/>
                            </div>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_shipment" model="ir.actions.report">
        <field name="name">Shipment</field>
        <field name="model">logistics.shipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">keralariders_logistics.report_shipment_document</field>
        <field name="report_file">keralariders_logistics.report_shipment_document</field>
        <field name="print_report_name">'AWB - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_logistics_shipment" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_shipping_label" />
    </record>
</odoo>