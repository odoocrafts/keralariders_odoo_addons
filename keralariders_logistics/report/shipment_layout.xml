<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="paperformat_shipping_label" model="report.paperformat">
        <field name="name">Shipping Label Paperformat</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10.00</field>
        <field name="margin_left">4.0</field>
        <field name="margin_right">4.0</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">10</field>
        <field name="dpi">90</field>
    </record>

    <template id="report_shipment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="company" t-value="o.company_id" />
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family:Arial,sans-serif;font-size:12px;"> <!--
                        HEADER -->
                        <table
                            style="width:100%;border-bottom:2px solid #222;margin-bottom:12px;padding-bottom:8px;">
                            <tr>
                                <td style="width:40%;text-align:left;">
                                    <h3 style="margin:0;font-size:16px;">
                                        <b>
                                            <u>AWB / Shipping Label</u>
                                        </b>
                                    </h3>
                                    <h4 style="margin:4px 0;font-size:13px;">
                                        <span t-field="o.name" />
                                    </h4>
                                </td>
                                <td class="text-end">
                                    <img
                                        t-att-src="'/report/barcode/Code128/%s?humanreadable=1&amp;width=288&amp;height=65' % o.name" />
                                </td>
                            </tr>
                        </table> <!--
                        SHIPMENT INFO -->
                        <table class="table table-sm table-bordered"
                            style="width:100%;margin-bottom:10px;font-size:10px;">
                            <tr style="background:#f2f2f2;">
                                <th colspan="4" style="padding:6px;font-size:11px;">
                                    <b>Shipment Information</b>
                                </th>
                            </tr>
                            <tr>
                                <td style="padding:4px;">
                                    <b>Seller</b>
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.seller_id" />
                                </td>
                                <td style="padding:4px;">
                                    <b>Est. Delivery</b>
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.estimated_delivery_date" />
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px;">
                                    <b>Order Date</b>
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.order_date" />
                                </td>
                                <td style="padding:4px;">
                                    <b>Payment Type</b>
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.order_payment_type" />
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px;">
                                    <b>Total Weight</b>
                                </td>
                                <td style="padding:4px;"><span t-field="o.total_weight" /> Kg</td>
                                <td style="padding:4px;">
                                    <b>COD Amount</b>
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.cod_amount" />
                                </td>
                            </tr>
                        </table> <!--
                        ADDRESSES -->
                        <table style="width:100%;margin-bottom:10px;">
                            <tr>
                                <td
                                    style="width:49%;vertical-align:top;border:1px solid #bbb;padding:8px;font-size:10px;">
                                    <div
                                        style="font-weight:bold;background:#f2f2f2;padding:4px;margin:-8px -8px 6px -8px;font-size:11px;">SHIP
                                    FROM</div> <b t-field="o.shipping_from_name" /><br /> <span
                                        t-field="o.shipping_from_address" /><br /> <span
                                        t-field="o.shipping_from_district_id" />, <span
                                        t-field="o.shipping_from_state_id" /><br /> <b>PIN:</b> <span
                                        t-field="o.shipping_from_zip" />
                                </td>
                                <td style="width:2%;"></td>
                                <td
                                    style="width:49%;vertical-align:top;border:1px solid #bbb;padding:8px;font-size:10px;">
                                    <div
                                        style="font-weight:bold;background:#f2f2f2;padding:4px;margin:-8px -8px 6px -8px;font-size:11px;">SHIP
                                    TO</div> <b t-field="o.shipping_to_name" /><br /> <span
                                        t-field="o.shipping_to_address" /><br /> <span
                                        t-field="o.shipping_to_district_id" />, <span
                                        t-field="o.shipping_to_state_id" /><br /> <b>PIN:</b> <span
                                        t-field="o.shipping_to_zip" /><br /> <b>Mobile:</b> <span
                                        t-field="o.shipping_to_mobile" /><br /> <b>Email:</b> <span
                                        t-field="o.shipping_to_email" />
                                </td>
                            </tr>
                        </table> <!--
                        BILLING -->
                        <table class="table table-sm table-bordered"
                            style="margin-bottom:8px;font-size:10px;">
                            <tr style="background:#f2f2f2;">
                                <th style="padding:6px;font-size:11px;">
                                    <b>Billing Address</b>
                                </th>
                            </tr>
                            <tr>
                                <td style="padding:6px;">
                                    <b t-field="o.billing_name" /><br /> <span
                                        t-field="o.billing_address" /><br /> <span
                                        t-field="o.billing_district_id" />, <span
                                        t-field="o.billing_state_id" /><br /> <b>PIN:</b> <span
                                        t-field="o.billing_zip" />
                                </td>
                            </tr>
                        </table> <!--
                        ITEM -->
                        <table class="table table-sm table-bordered"
                            style="margin-bottom:8px;font-size:10px;">
                            <tr style="background:#f2f2f2;">
                                <th colspan="2" style="padding:6px;font-size:11px;">
                                    <b>Shipment Details</b>
                                </th>
                            </tr>
                            <tr>
                                <td style="padding:4px;">
                                    <b>Item Description</b>
                                </td>
                                <td style="padding:4px;">
                                    <b>Total Order Value</b>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px;">
                                    <span t-field="o.item_description" />
                                </td>
                                <td style="padding:4px;">
                                    <span t-field="o.total_order_value" />
                                </td>
                            </tr>
                        </table>
                        <div style="clear:both;"></div> <!-- NOTES -->
                        <div
                            style="border:1px solid #ccc;padding:8px;margin-top:8px;font-size:10px;">
                            <b>Notes</b>
                            <br />
                            <span t-field="o.seller_notes" />
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_shipment" model="ir.actions.report">
        <field name="name">Shipment</field>
        <field name="model">logistics.shipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">keralariders_logistics.report_shipment_document</field>
        <field name="report_file">keralariders_logistics.report_shipment_document</field>
        <field name="print_report_name">'AWB - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_logistics_shipment" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_shipping_label" />
    </record>
</odoo>