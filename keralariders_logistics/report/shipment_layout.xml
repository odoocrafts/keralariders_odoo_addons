<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template id="report_shipment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="company" t-value="o.company_id"/>
                <t t-call="web.external_layout">

                    <div class="page">

                        <!-- HEADER -->

                        <table style="width:100%;border-bottom:2px solid #222;margin-bottom:20px;">
                            <tr>

                                <td style="width:40%;text-align:left;">
                                    <h3 style="margin:0;"><b><u>Delivery Note</u></b></h3>
                                    <h4 style="margin:0;">
                                        <span t-field="o.name"/>
                                    </h4>
                                </td>
                                <td class="text-end">
                                    <img t-att-src="'/report/barcode/Code128/%s?humanreadable=1&amp;width=288&amp;height=65' % o.name"/>
                                </td>

                            </tr>
                        </table>


                        <!-- SHIPMENT INFO -->

                        <table class="table table-sm table-bordered"
                               style="width:100%;margin-bottom:20px;">

                            <tr style="background:#f2f2f2;">
                                <th colspan="4">
                                    Shipment Information
                                </th>
                            </tr>

                            <tr>
                                <td><strong>Seller</strong></td>
                                <td><span t-field="o.seller_id"/></td>

                                <td><strong>Status</strong></td>
                                <td><span t-field="o.state"/></td>
                            </tr>

                            <tr>
                                <td><strong>Order Date</strong></td>
                                <td><span t-field="o.order_date"/></td>

                                <td><strong>Payment Type</strong></td>
                                <td><span t-field="o.order_payment_type"/></td>
                            </tr>

                            <tr>
                                <td><strong>Delivery Executive</strong></td>
                                <td><span t-field="o.delivery_executive_id"/></td>

                                <td><strong>Estimated Delivery</strong></td>
                                <td><span t-field="o.estimated_delivery_date"/></td>
                            </tr>

                            <tr>
                                <td><strong>Total Weight</strong></td>
                                <td>
                                    <span t-field="o.total_weight"/> Kg
                                </td>

                                <td><strong>COD Amount</strong></td>
                                <td>
                                    <span t-field="o.cod_amount"/>
                                </td>
                            </tr>

                        </table>


                        <!-- ADDRESSES -->

                        <table style="width:100%;margin-bottom:20px;">

                            <tr>

                                <!-- FROM -->

                                <td style="width:49%;vertical-align:top;border:1px solid #bbb;padding:10px;">

                                    <div style="font-weight:bold;background:#f2f2f2;padding:5px;margin:-10px -10px 10px -10px;">
                                        SHIP FROM
                                    </div>

                                    <strong t-field="o.shipping_from_name"/>

                                    <br/>

                                    <span t-field="o.shipping_from_address"/>

                                    <br/>

                                    <span t-field="o.shipping_from_district_id"/>
                                    ,

                                    <span t-field="o.shipping_from_state_id"/>

                                    <br/>

                                    PIN :
                                    <span t-field="o.shipping_from_zip"/>

                                </td>


                                <td style="width:2%;"></td>


                                <!-- TO -->

                                <td style="width:49%;vertical-align:top;border:1px solid #bbb;padding:10px;">

                                    <div style="font-weight:bold;background:#f2f2f2;padding:5px;margin:-10px -10px 10px -10px;">
                                        SHIP TO
                                    </div>

                                    <strong t-field="o.shipping_to_name"/>

                                    <br/>

                                    <span t-field="o.shipping_to_address"/>

                                    <br/>

                                    <span t-field="o.shipping_to_district_id"/>

                                    ,

                                    <span t-field="o.shipping_to_state_id"/>

                                    <br/>

                                    PIN :
                                    <span t-field="o.shipping_to_zip"/>

                                    <br/>

                                    Mobile :
                                    <span t-field="o.shipping_to_mobile"/>

                                    <br/>

                                    Email :
                                    <span t-field="o.shipping_to_email"/>

                                </td>

                            </tr>

                        </table>


                        <!-- BILLING -->

                        <table class="table table-sm table-bordered">

                            <tr style="background:#f2f2f2;">
                                <th>
                                    Billing Address
                                </th>
                            </tr>

                            <tr>

                                <td>

                                    <strong t-field="o.billing_name"/>

                                    <br/>

                                    <span t-field="o.billing_address"/>

                                    <br/>

                                    <span t-field="o.billing_district_id"/>

                                    ,

                                    <span t-field="o.billing_state_id"/>

                                    <br/>

                                    PIN :
                                    <span t-field="o.billing_zip"/>

                                </td>

                            </tr>

                        </table>


                        <br/>


                        <!-- ITEM -->

                        <table class="table table-sm table-bordered">

                            <tr style="background:#f2f2f2;">
                                <th colspan="2">
                                    Shipment Details
                                </th>
                            </tr>

                            <tr>

                                <td width="30%">
                                    Item Description
                                </td>

                                <td>
                                    <span t-field="o.item_description"/>
                                </td>

                            </tr>

                            <tr>

                                <td>
                                    Total Order Value
                                </td>

                                <td>
                                    <span t-field="o.total_order_value"/>
                                </td>

                            </tr>

                        </table>


                        <br/>


                        <!-- CHARGES -->

                        <table style="width:40%;float:right;"
                               class="table table-sm table-bordered">

                            <tr style="background:#f2f2f2;">
                                <th colspan="2">
                                    Charges
                                </th>
                            </tr>

                            <tr>

                                <td>Subtotal</td>

                                <td style="text-align:right;">
                                    <span t-field="o.delivery_charges_subtotal"/>
                                </td>

                            </tr>

                            <tr>

                                <td>Tax</td>

                                <td style="text-align:right;">
                                    <span t-esc="o.tax_percentage * 100"/> %
                                </td>

                            </tr>

                            <tr>

                                <td>
                                    <strong>Total</strong>
                                </td>

                                <td style="text-align:right;">
                                    <strong>
                                        <span t-field="o.delivery_charges_total"/>
                                    </strong>
                                </td>

                            </tr>

                        </table>

                        <div style="clear:both;"></div>

                        <br/>

                        <!-- NOTES -->

                        <div style="border:1px solid #ccc;padding:10px;">

                            <strong>Seller Notes</strong>

                            <br/>

                            <span t-field="o.seller_notes"/>

                        </div>
                    </div>

                </t>

            </t>

        </t>

    </template>

    <record id="action_report_shipment" model="ir.actions.report">
        <field name="name">Shipment</field>
        <field name="model">logistics.shipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">keralariders_logistics.report_shipment_document</field>
        <field name="report_file">keralariders_logistics.report_shipment_document</field>
        <field name="print_report_name">'AWB - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_logistics_shipment"/>
        <field name="binding_type">report</field>
    </record>
</odoo>