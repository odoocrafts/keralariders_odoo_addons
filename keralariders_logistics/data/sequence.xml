<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="seq_shipment" model="ir.sequence">
            <field name="name">Shipment Sequence</field>
            <field name="code">logistics.shipment</field>
            <field name="prefix">%(y)s%(month)s</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_recharge_request" model="ir.sequence">
            <field name="name">Recharge Request Sequence</field>
            <field name="code">logistics.wallet.recharge.request</field>
            <field name="prefix">RECH%(y)s%(month)s</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
</odoo>